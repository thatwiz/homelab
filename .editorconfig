root = true

[*]
end_of_line = lf
indent_style = space
indent_size = 2
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

# YAML and JSON configuration
[*.{yaml,yml,json}]
indent_style = space
indent_size = 2

# Backend & Systems Languages Overrides
[*.{py,rs,java}]
indent_size = 4
